		HD FCEV bid share
	~	t H2
	~		|

IA equalizer=
	IF THEN ELSE( BioKero H2 subsidy>0.01 , 
	   IF THEN ELSE( SynKero H2 subsidy>0.01 , 
	                (1-SynKero IA bid share-BioKero IA bid share)/(Jetfuel IA level) ,
	                (1-BioKero IA bid share)/(SynKero IA level+Jetfuel IA level)) , 
	   IF THEN ELSE( SynKero H2 subsidy>0.01 ,
	                (1-SynKero IA bid share)/(BioKero IA level+Jetfuel IA level) ,
	                 1/(BioKero IA level+SynKero IA level+Jetfuel IA level))
	)
	~	Dmnl
	~		|

BioMeOH HBA volume=
