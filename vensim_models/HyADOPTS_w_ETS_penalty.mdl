		 )
	~	
	~		|

equalizer MeOH=
	IF THEN ELSE( BioMeOH H2 subsidy>0.01 , 
	   IF THEN ELSE( eMeOH H2 subsidy>0.01 , 
	                (1-eMeOH bid share-BioMeOH bid share)/(Grey MeOH level+Blue MeOH level\
		) ,
	                (1-BioMeOH bid share)/(eMeOH level+Grey MeOH level+Blue MeOH level))\
		 , 
	   IF THEN ELSE( eMeOH H2 subsidy>0.01 ,
	                (1-eMeOH bid share)/(BioMeOH level+Grey MeOH level+Blue MeOH level) \
		,
	                 1/(BioMeOH level+eMeOH level+Grey MeOH level+Blue MeOH level))
	)
	~	
