{UTF-8}
HFO IS economic decommissioning=IF THEN ELSE ( HFO IS cost difference > 1 
		, (HFO IS / containership lifetime * 3) * (1/(1+EXP(-SLOPE DECOM*(HFO IS cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

HFO DS economic decommissioning=IF THEN ELSE ( HFO DS cost difference > 1
		, (HFO DS / ship lifetime * 3 ) * (1/(1+EXP(-SLOPE DECOM*(HFO DS cost difference-INTERSEC DECOM\
		))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

Grey NH3 economic decommissioning=IF THEN ELSE ( Grey NH3 cost difference > 1
		, (Grey NH3 / SMR lifetime * 3) * (1/(1+EXP(-SLOPE DECOM*(Grey NH3 cost difference-\
		INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	MT NH3/Year
	~		|

Jetfuel IA economic decommissioning=IF THEN ELSE ( Jetfuel cost difference > 1
		, (Jetfuel IA / jetfuel lockin period * 3 ) * (1/(1+EXP(-SLOPE DECOM*(Jetfuel cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

Fossil naphtha economic decommissioning=IF THEN ELSE ( Fossil naphtha cost difference\
		 > 1
		, (Fossil naphtha / feedstock lockin period * 3) * (1/(1+EXP(-SLOPE DECOM*(Fossil naphtha cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	MT naphtha/Year
	~		|

BF BOF economic decommissioning=IF THEN ELSE ( BF BOF cost difference > 1
		, (BF BOF / foundry lifetime * 3) * (1/(1+EXP(-SLOPE DECOM*(BF BOF cost difference-\
		INTERSEC DECOM))))
		, 0 
	) * ECONOMIC DECOMMISSIONING
	~	MT steel/Year
	~		|

Grey NG NM economic decommissioning=IF THEN ELSE ( Grey NG NM cost difference > 1
		, (Grey NG NM / Gas lockin period * 3) * (1/(1+EXP(-SLOPE DECOM*(Grey NG NM cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

Jetfuel DA economic decommissioning=IF THEN ELSE ( Jetfuel cost difference > 1
		, (Jetfuel DA / jetfuel lockin period * 3) * (1/(1+EXP(-SLOPE DECOM*(Jetfuel cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

LD fossil economic decommissioning=IF THEN ELSE ( LD fossil cost difference > 1 
		, (LD Fossil / car lifetime * 3 ) * (1/(1+EXP(-SLOPE DECOM*(LD fossil cost difference\
		-INTERSEC DECOM))))
		, 0 
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

INTERSEC DECOM=1.5
	~	unitless
	~		|

Grey Refinery Economic Decommissioning=IF THEN ELSE (Grey H2 cost difference > 1 
		, (Grey Refinery / SMR lifetime * 3) * (1/(1+EXP(-SLOPE DECOM*(Grey H2 cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	MT H2 / Year
	~		|

Grey MeOH economic decommissioning=IF THEN ELSE ( Grey MeOH cost difference > 1
		, (Grey MeOH / MeOH plant lifetime * 3 ) * (1/(1+EXP(-SLOPE DECOM*(Grey MeOH cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	MT MeOH/Year
	~		|

HD fossil economic decommissioning=IF THEN ELSE ( HD fossil cost difference > 1 
		, (HD Fossil / truck lifetime * 3 ) * (1/(1+EXP(-SLOPE DECOM*(HD fossil cost difference\
		-INTERSEC DECOM))))
		, 0
	) * ECONOMIC DECOMMISSIONING
	~	GWh/Year
	~		|

SLOPE DECOM=10
	~	unitless
	~		|

BF BOF cost=IF THEN ELSE ( steel excess emissions > 0 ,
	 CARBON TAX W PENALTY * BF Coal emission factor  ,
	 CARBON TAX * BF Coal emission factor  ) +
	COAL PRICE * (Coal to Steel * Coal LHV) +
	GRID ELECTRICITY PRICE * EL to Steel BF Coal +
	BF Coal CAPEX / (foundry operating hours/8760) * foundry AF * INFLATION LOOKUP(2022)
	~	€/tsteel
	~	OPEX as well as iron ore/steel raw material costs are assumed identical \
		across technologies.
	|

sum fertilizer decommissioning=Blue NH3 Decommissioning+Green NH3 Decommissioning+Grey NH3 Decommissioning\
		+Grey NH3 economic decommissioning
	~	MT NH3/Year
	~		|

Grey NH3 cost=IF THEN ELSE ( fertilizer excess activity > 0 ,
	 CARBON TAX W PENALTY * (Grey NH3 EF / NH3 LHV) ,
	 CARBON TAX * (Grey NH3 EF / NH3 LHV) ) 
	+ Grey NH3 cost without CO2
	~	€/GJ
	~		|

Grey Refinery= INTEG (Grey Refinery Commissioning-Grey Refinery Decommissioning-Grey Refinery Economic Decommissioning\
		,
		refinery initial sector activity)
	~	MT H2
	~		|

Jetfuel IA economic decommissioning delayed=DELAY N ( Jetfuel IA economic decommissioning\
		, 3 , 0, 10 )
	~	GWh/Year
	~		|

Fossil naphtha economic decommissioning delayed=DELAY N ( Fossil naphtha economic decommissioning\
		, 3 , 0, 10 )
	~	MT naphtha/Year
	~		|

sum high temperature decommissioning=Biogas Decommissioning+Blue NG NM Decommissioning\
		+Grey NG NM Decommissioning+H2 NM Decommissioning+Grey NG NM economic decommissioning
	~	GWh/Year
	~		|

sum MeOH decommissioning=BioMeOH Decommissioning+Blue MeOH Decommissioning+eMeOH Decommissioning\
		+Grey MeOH Decommissioning
	+Grey MeOH economic decommissioning
	~	MT MeOH
	~		|

sum IA decommissioning=BioKero IA Decommissioning+Jetfuel IA Decommissioning+SynKero IA Decommissioning
	+Jetfuel IA economic decommissioning
	~	GWh/Year
	~		|

Naphtha cost=IF THEN ELSE ( naphtha excess activity > 0 ,
	 CARBON TAX W PENALTY * Naphtha emission factor ,
	 CARBON TAX * Naphtha emission factor )
	+ Naphtha cost wo CO2
	~	€/GJ
	~	Per energy content it is assumed that the cost of naphtha is 10% higher than the \
		crude oil cost.
		Based on average market price difference observed the last 12 months (anno May \
		2024). Source:
		https://tradingeconomics.com/commodity/naphtha
	|

Grey NH3 economic decommissioning delayed=DELAY N ( Grey NH3 economic decommissioning\
		, 3 , 0, 10 )
	~	MT NH3/Year
	~		|

Grey Refinery Economic Decommissioning delayed=DELAY N ( Grey Refinery Economic Decommissioning\
		, 3 , 0, 10 )
	~	MT H2/Year
	~		|

LD Fossil Economic Decommissioning delayed=DELAY N ( LD fossil economic decommissioning\
		 + LD Fossil Early Decommissioning, 3 , 0, 10 )
	~	GWh/Year
	~		|

Jetfuel DA= INTEG (Jetfuel DA Commissioning-Jetfuel DA Decommissioning-Jetfuel DA economic decommissioning\
		,
		DA initial sector activity)
	~	GWh
	~		|

Grey H2 cost=IF THEN ELSE ( refinery excess activity > 0 ,
	 CARBON TAX W PENALTY * Grey H2 EF / 1000 ,
	 CARBON TAX * Grey H2 EF / 1000 ) 
	+ Grey H2 cost wo CO2
	~	€/kgH2
	~	€/kg grey H2
	|

Grey NG NM Economic Decommissioning delayed=DELAY N ( Grey NG NM economic decommissioning\
		, 3 , 0, 10 )
	~	GWh/Year
	~		|

HFO cost=IF THEN ELSE ( MAX ( IS excess activity , DS excess activity ) > 0 ,
	 CARBON TAX W PENALTY * HFO emission factor ,
	 CARBON TAX * HFO emission factor ) 
	+ OIL PRICE
	~	€/GJ
	~	€/GJ Oil
	|

HFO DS= INTEG (HFO DS Commissioning-HFO DS Decommissioning-HFO DS economic decommissioning\
		,
		DS initial sector activity)
	~	GWh
	~		|

HFO DS economic decommissioning delayed=DELAY N ( HFO DS economic decommissioning, 3 \
		, 0, 10 )
	~	GWh/Year
	~		|

HD Fossil economic decommissioning delayed=DELAY N ( HD fossil economic decommissioning\
		 + HD Fossil Early Decommissioning, 3 , 0, 10 )
	~	GWh/Year
	~		|

sum refinery decommissioning=Blue Refinery Decommissioning+Green Refinery Decommissioning\
		+Grey Refinery Decommissioning+
	Grey Refinery Economic Decommissioning
	~	MT H2/Year
	~		|

BF BOF economic decommissioning delayed=DELAY N ( BF BOF economic decommissioning, 3 \
		, 0, 10 )
	~	MT steel/Year
	~		|

Grey NH3= INTEG (Grey NH3 Commissioning-Grey NH3 Decommissioning-Grey NH3 economic decommissioning\
		,
		fertilizer initial sector activity)
	~	MT NH3
	~		|

sum steel decommissioning=BF BOF CCS Decommissioning+BF BOF Decommissioning+H2DRI EAF Decommissioning
	+NGDRI EAF Decommissioning+BF BOF economic decommissioning
	~	MT steel/Year
	~		|

HFO IS economic decommissioning delayed=DELAY N ( HFO IS economic decommissioning, 3 \
		, 0, 10 )
	~	GWh/Year
	~		|

Jetfuel cost=IF THEN ELSE ( MAX(IA excess emissions,DA excess emissions) * Hard Regulation\
		 > 0 ,
	 CARBON TAX W PENALTY * Jetfuel emission factor ,
	 CARBON TAX * Jetfuel emission factor ) 
	+ Jetfuel cost wo CO2
	~	€/GJ
	~		|

convMeOH cost=(
	IF THEN ELSE ( MeOH excess activity > 0 ,
	 convMeOH emission factor * CARBON TAX ,
	 convMeOH emission factor * CARBON TAX W PENALTY ) +
	convMeOH electricity usage * GRID ELECTRICITY PRICE +
	convMeOH gas usage * GAS PRICE + 
	convMeOH OPEX + 
	convMeOH CAPEX * convMeOH AF) / MeOH LHV
	~	€/GJ
	~		|

Grey MeOH= INTEG (Grey MeOH Commissioning-Grey MeOH Decommissioning-Grey MeOH economic decommissioning\
		,
		MeOH initial sector activity)
	~	MT MeOH
	~		|

BF BOF= INTEG (BF BOF Commissioning-BF BOF Decommissioning-BF BOF economic decommissioning\
		,
		steel initial sector activity)
	~	MT steel
	~		|

Grey NG cost=IF THEN ELSE ( high temperature excess activity > 0 ,
	 CARBON TAX W PENALTY * GAS EMISSION FACTOR ,
	 CARBON TAX * GAS EMISSION FACTOR ) 
	+ GAS PRICE
	~	€/GJ
	~		|

Grey NG NM= INTEG (Grey NG NM Commissioning-Grey NG NM Decommissioning-Grey NG NM economic decommissioning\
		,
		high temperature initial sector activity)
	~	GWh
	~		|

HFO IS= INTEG (HFO IS Commissioning-HFO IS Decommissioning-HFO IS economic decommissioning\
		,
		IS initial sector activity)
	~	GWh
	~		|

sum naphtha decommissioning=BioNaphtha Decommissioning+Fossil naphtha Decommissioning\
		+SynNaphtha Decommissioning
	+Fossil naphtha economic decommissioning
	~	MT naphtha
	~		|

sum IS decommissioning=MeOH IS Decommissioning+HFO IS Decommissioning+NH3 IS Decommissioning
	+HFO IS economic decommissioning
	~	GWh/Year
	~		|

sum DA decommissioning=BioKero DA Decommissioning+Jetfuel DA Decommissioning+SynKero DA Decommissioning
	+Jetfuel DA economic decommissioning
	~	GWh/Year
	~		|

CARBON TAX W PENALTY=CARBON TAX + 100
	~	€/tCO2
	~	source for penalty:
		https://climate.ec.europa.eu/eu-action/carbon-markets/eu-emissions-trading-\
		system-eu-ets/monitoring-reporting-and-verification_en
	|

Jetfuel DA economic decommissioning delayed=DELAY N ( Jetfuel DA economic decommissioning\
		, 3 , 0, 10 )
	~	GWh/Year
	~		|

Fossil naphtha= INTEG (Fossil naphtha Commissioning-Fossil naphtha Decommissioning-
	Fossil naphtha economic decommissioning,
		naphtha initial sector activity)
	~	MT naphtha
	~		|

sum DS decommissioning=MeOH DS Decommissioning+HFO DS Decommissioning+Electric DS Decommissioning
	+H2FC DS Decommissioning+HFO DS economic decommissioning
	~	GWh/Year
	~		|

Jetfuel IA= INTEG (Jetfuel IA Commissioning-Jetfuel IA Decommissioning-Jetfuel IA economic decommissioning\
		,
		IA initial sector activity)
	~	GWh
	~		|

Grey MeOH economic decommissioning delayed=DELAY N ( Grey MeOH economic decommissioning\
		, 3 , 0, 10 )
	~	MT MeOH/Year
	~		|

Fossil naphtha Decommissioning=MAX(0,
	MIN ( SMOOTH( Fossil Naphtha delayed - Fossil naphtha economic decommissioning delayed\
		 , 1 ) 
	, Fossil naphtha ) 
	)
	~	MT naphtha/Year
	~		|

Fossil Naphtha delayed=DELAY FIXED ( Fossil naphtha Commissioning , feedstock lockin period\
		 , naphtha initial sector activity/feedstock lockin period )
	~	MT naphtha/Year
	~		|

Grey MeOH delayed=DELAY FIXED ( Grey MeOH Commissioning , MeOH plant lifetime , MeOH initial sector activity\
		 / MeOH plant lifetime )
	~	MT MeOH/Year
	~		|

Jetfuel IA Decommissioning=MAX ( 0 , 
	MIN ( SMOOTH ( Jetfuel IA delayed - Jetfuel IA economic decommissioning delayed , 1 \
		) 
	, Jetfuel IA ) 
	)
	~	GWh/Year
	~		|

HD Fossil Decommissioning=MAX ( 0 , 
	MIN ( SMOOTH ( HD Fossil delayed - HD Fossil economic decommissioning delayed , 1 )  
	, HD Fossil )  
	)
	~	GWh/Year
	~		|

Jetfuel DA delayed=DELAY FIXED ( Jetfuel DA Commissioning , jetfuel lockin period , DA initial sector activity\
		 / jetfuel lockin period )
	~	GWh/Year
	~		|

Grey NG NM Delayed=DELAY FIXED ( Grey NG NM Commissioning , Gas lockin period , high temperature initial sector activity\
		/Gas lockin period)
	~	GWh/Year
	~		|

Grey NH3 Decommissioning=MAX(0,
	MIN ( SMOOTH ( Grey NH3 delayed - Grey NH3 economic decommissioning delayed , 1 )  
	, Grey NH3 ) 
	)
	~	MT NH3/Year
	~		|

Grey NH3 delayed=DELAY FIXED ( Grey NH3 Commissioning , SMR lifetime , fertilizer initial sector activity\
		/SMR lifetime )
	~	MT NH3/Year
	~		|

Grey Refinery Decommissioning=MAX(0,
	MIN( SMOOTH(Grey Refinery delayed - Grey Refinery Economic Decommissioning delayed,1\
		)
	, Grey Refinery )
	)
	~	MT H2/Year
	~		|

Grey Refinery delayed=DELAY FIXED ( Grey Refinery Commissioning , SMR lifetime , refinery initial sector activity\
		/SMR lifetime
	)
	~	MT H2/Year
	~		|

LD Fossil Decommissioning=MAX(0,
	MIN ( SMOOTH ( LD Fossil delayed - LD Fossil Economic Decommissioning delayed , 1 ) 
	, LD Fossil ) 
	)
	~	GWh/Year
	~		|

LD Fossil delayed=DELAY FIXED ( LD Fossil Commissioning , car lifetime , LD initial sector activity\
		 / car lifetime )
	~	GWh/Year
	~		|

Grey MeOH Decommissioning=MAX(0,
	MIN ( SMOOTH ( Grey MeOH delayed - Grey MeOH economic decommissioning delayed , 1 )  
	, Grey MeOH ) 
	)
	~	MT MeOH/Year
	~		|

HFO IS delayed=DELAY FIXED ( HFO IS Commissioning , containership lifetime , IS initial sector activity\
		 / containership lifetime  )
	~	GWh/Year
	~		|

HFO DS Decommissioning=MAX ( 0 , 
	MIN ( SMOOTH ( HFO DS delayed - HFO DS economic decommissioning delayed, 1 ) 
	, HFO DS ) 
	)
	~	GWh/Year
	~		|

Jetfuel DA Decommissioning=MAX ( 0 ,
	MIN (SMOOTH ( Jetfuel DA delayed - Jetfuel DA economic decommissioning delayed , 1 )\
		 
	, Jetfuel DA ) 
	)
	~	GWh/Year
	~		|

HFO DS delayed=DELAY FIXED ( HFO DS Commissioning , ship lifetime , DS initial sector activity\
		/ship lifetime )
	~	GWh/Year
	~		|

HD Fossil delayed=DELAY FIXED ( HD Fossil Commissioning , truck lifetime , HD initial sector activity\
		/truck lifetime  )
	~	GWh/Year
	~		|

BF BOF Decommissioning=MAX(0,
	MIN( SMOOTH ( BF BOF delayed - BF BOF economic decommissioning delayed , 1 ) 
	, BF BOF ) 
	)
	~	MT steel/Year
	~		|

BF BOF delayed=DELAY FIXED ( BF BOF Commissioning , foundry lifetime , steel initial sector activity\
		/foundry lifetime )
	~	MT steel/Year
	~		|

Grey NG NM Decommissioning=MAX(0,
	MIN ( SMOOTH( Grey NG NM Delayed - Grey NG NM Economic Decommissioning delayed , 1 )\
		  
	, Grey NG NM ) 
	)
	~	GWh/Year
	~		|

HFO IS Decommissioning=MAX ( 0 ,
	MIN ( SMOOTH ( HFO IS delayed - HFO IS economic decommissioning delayed , 1 )  
	, HFO IS ) 
	 )
	~	GWh/Year
	~		|

Jetfuel IA delayed=DELAY FIXED ( Jetfuel IA Commissioning, jetfuel lockin period , IA initial sector activity\
		/jetfuel lockin period )
	~	GWh/Year
	~		|

sum HD decommissioning=HD FCEV Decommissioning+HD Fossil Decommissioning+HD Fossil Early Decommissioning\
		+HD BEV Decommissioning+HD fossil economic decommissioning
	~	GWh/Year
	~		|

sum LD decommissioning=LD FCEV Decommissioning+LD Fossil Decommissioning+LD Fossil Early Decommissioning\
		+LD BEV Decommissioning+LD fossil economic decommissioning
	~	GWh/Year
	~		|

Blue Refinery Decommissioning=IF THEN ELSE ( Blue Refinery delayed > Blue Refinery ,
	Blue Refinery ,
	Blue Refinery delayed )
	~	MT H2/Year
	~		|

Grey NH3 cost difference=Grey NH3 cost marginal / alternative fertilizer cost
	~	factor
	~		|

Grey NH3 cost marginal=Grey NH3 cost - NH3 CAPEX*NH3 AF/(Grey NH3 operating hours*NH3 LHV\
		)*1000
	~	€/GJ
	~		|

Green Refinery Decommissioning=IF THEN ELSE ( Green Refinery delayed>Green Refinery,
	Green Refinery,
	Green Refinery delayed)
	~	MT H2/Year
	~		|

Jetfuel cost difference=Jetfuel cost / alternative Jetfuel cost
	~	factor
	~		|

convMeOH cost marginal=convMeOH cost - convMeOH CAPEX * convMeOH AF / MeOH LHV
	~	€/GJ
	~		|

HFO containership cost marginal=HFO containership cost - HFO Ship CAPEX*Ship engine AF
	~	M€/Year
	~		|

electrolyzer decommissioning=IF THEN ELSE ( electrolyzer investments delayed > electrolyser capacity\
		,
	electrolyser capacity,
	electrolyzer investments delayed)
	~	GW/Year
	~		|

alternative fertilizer cost=MIN ( Blue NH3 cost , fertilizer NH3 cost )
	~	€/GJ
	~		|

alternative H2 cost=MIN ( Blue H2 cost , refinery H2 cost )
	~	€/kgH2
	~		|

alternative HD cost=MIN ( HD BE LCO , HD FC LCO )
	~	€/km
	~		|

alternative HT cost=MIN ( biogas cost , MIN ( Blue NG cost , NM H2 GJ cost ))
	~	€/GJ
	~		|

alternative Jetfuel cost=MIN ( BioKero cost , SynKero cost )
	~	€/GJ
	~		|

HFO DS cost difference=HFO ship cost / min green ship cost
	~	factor
	~		|

alternative MeOH cost=MIN ( Blue MeOH cost , MIN ( Green bioMeOH cost , Green eMeOH cost\
		 )  )
	~	€/GJ
	~		|

alternative naphtha cost=MIN ( BioNaphtha cost , SynNaphtha cost )
	~	€/GJ
	~		|

alternative steel cost=MIN ( BF BOF CCS cost , H2DRI cost )
	~	€/tsteel
	~		|

BF BOF cost marginal=BF BOF cost - BF Coal CAPEX / (foundry operating hours/8760) * foundry AF\
		 * INFLATION LOOKUP(2022)
	~	€/tsteel
	~		|

Grey NG NM cost difference=Grey NG cost / alternative HT cost
	~	factor
	~		|

HD fossil cost difference=HD ICE OPEX / alternative HD cost
	~	factor
	~		|

HFO IS cost difference=HFO containership cost marginal/min green containership cost
	~	factor
	~		|

ECONOMIC DECOMMISSIONING=1
	~	boolean
	~		|

Blue Refinery delayed=DELAY FIXED ( Blue Refinery Commissioning , SMR lifetime , 0 )
	~	MtH2
	~		|

Fossil naphtha cost difference=Naphtha cost / alternative naphtha cost
	~	factor
	~		|

Green Refinery delayed=DELAY FIXED ( Green Refinery Commissioning , AEC lifetime , 0 \
		)
	~	MtH2
	~		|

BF BOF cost difference=BF BOF cost marginal / alternative steel cost
	~	factor
	~		|

Grey H2 cost marginal=Grey H2 cost - (SMR CAPEX*SMR AF/SMR Capacity Factor)/1000
	~	€/kgH2
	~		|

electrolyzer investments delayed=DELAY FIXED ( electrolyzer investments , AEC lifetime\
		 , 0 )
	~	GW/yr
	~		|

Grey MeOH cost difference=convMeOH cost marginal / alternative MeOH cost
	~	factor
	~		|

Grey H2 cost difference=Grey H2 cost marginal / alternative H2 cost
	~	factor
	~		|

LD fossil cost difference=LD ICE OPEX / LD BE LCO
	~	factor
	~		|

HD Fossil= INTEG (HD Fossil Commissioning-HD Fossil Decommissioning-HD Fossil Early Decommissioning\
		-HD fossil economic decommissioning,
		HD initial sector activity * 0.986)
	~	GWh
	~		|

LD Fossil= INTEG (LD Fossil Commissioning-LD Fossil Decommissioning-LD Fossil Early Decommissioning\
		-LD fossil economic decommissioning,
		LD initial sector activity * 0.986)
	~	GWh
	~		|

NH3 IS H2 subsidy size=IF THEN ELSE(
	MAX(MIN(NH3 IS H2 WTP gap + bid increase, HBA max subsidy), NH3 IS H2 WTP gap) <= HBA auction cleared
	, 
	MAX(0.001, MIN(HBA max subsidy, NH3 IS H2 WTP gap + bid increase)), 
	0)
	~	€/kg
	~		|

NH3 IS H2 WTP gap=Unsubsidized green H2 cost-NH3 containership H2 WTP
	~	€/kgH2
	~		|

MeOH DS H2 subsidy size=IF THEN ELSE(
	MAX(MIN(MeOH DS H2 WTP gap + bid increase, HBA max subsidy), MeOH DS H2 WTP gap) <= \
		HBA auction cleared
	, 
	MAX(0.001, MIN(HBA max subsidy, MeOH DS H2 WTP gap + bid increase)),
	0)
	~	€/kg
	~		|

BioMeOH H2 subsidy size=IF THEN ELSE(
	MAX(MIN(BioMeOH H2 WTP gap + bid increase, HBA max subsidy), BioMeOH H2 WTP gap) <= \
		HBA auction cleared
	, 
	MAX(0.001, MIN(HBA max subsidy, BioMeOH H2 WTP gap + bid increase)), 
	0)
	~	€/kg
	~		|

HD FCEV H2 subsidy size=IF THEN ELSE(
	MAX(MIN(HD FCEV H2 WTP gap + bid increase, HBA max subsidy), HD FCEV H2 WTP gap) <= \
		HBA auction cleared
	,
	MAX(0.001, MIN(HBA max subsidy, HD FCEV H2 WTP gap + bid increase)),
	0)
	~	€/kg
	~		|

LD FCEV H2 subsidy size=IF THEN ELSE(
	MAX(MIN(LD FCEV H2 WTP gap + bid increase, HBA max subsidy), LD FCEV H2 WTP gap) <= \
		HBA auction cleared
	,
	MAX(0.001, MIN(HBA max subsidy, LD FCEV H2 WTP gap + bid increase)), 
	0)
	~	€/kg
	~		|

LD FCEV H2 WTP gap=Unsubsidized green H2 cost-LD H2 WTP
	~	€/kgH2
	~		|

Green Refinery H2 WTP gap=Unsubsidized green H2 cost-refinery H2 WTP
	~	€/kgH2
	~		|

BioKero H2 subsidy size=IF THEN ELSE(
	MAX(MIN(BioKero H2 WTP gap + bid increase, HBA max subsidy), BioKero H2 WTP gap) <= \
		HBA auction cleared
	,
	MAX(0.001, MIN(HBA max subsidy, BioKero H2 WTP gap +bid increase)),
	0)
	~	€/kg
	~		|

SynKero H2 subsidy size=IF THEN ELSE(
	MAX(MIN(SynKero H2 WTP gap + bid increase, HBA max subsidy), SynKero H2 WTP gap) <= \
		HBA auction cleared
	,
	MAX(0.001, MIN(HBA max subsidy, SynKero H2 WTP gap + bid increase)),
	0)
	~	€/kg
