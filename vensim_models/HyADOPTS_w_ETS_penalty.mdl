	~	MT
	~	Common capacity found in \
		https://globalenergymonitor.org/projects/global-steel-plant-tracker/tracker\
		-map/
	|

HFO containership cost=
	Containership OPEX +
	HFO Ship CAPEX * Ship engine AF +
	(HFO cost * 3600 + Scrubber cost * 1000) * Yearly Containership Consumption / 10^6
	~	M€/Year
	~		|

FC ship cost without H2=
	(Auxilliary battery capacity * Battery cost * ( OPEX electric ship + Ship battery AF\
		 ) +
	Ship motor capacity * ( Electric motor cost * ( Ship engine AF + OPEX electric ship \
		)  + FC cost * ( FC AF + OPEX electric ship
	 ) ) +
	(Rest of ship cost + H2 capacity * H2 storage cost) * ( OPEX electric ship + Ship engine AF\
		 )) /10^6
	~	M€/Year
	~		|

MeOH ship cost without MeOH=
	((( OPEX ICE ship + Ship engine AF ) *
	(
	  Rest of ship cost +
	  HFO capacity * Oil tank cost +
	  Ship motor capacity * Ship ICE cost
	) +
	( OPEX ICE ship + Ship battery AF ) * Auxilliary battery capacity * Battery cost)
	* HFO vs MeOH CAPEX) /10^6
	~	M€/Year
	~		|

bioMeOH learning rate=
	0.03
	~	
	~		|

bioMeOH plant size=
	400*19.9/3.6
	~	GWh/Year
	~	400 kt MeOH per year
	|

CT OPEX=
	20
	~	€/(tCO2/h)/km/Year
	~		|

Carbon Transportation cost=
	CT distance *
	( CT CAPEX * CT AF + CT OPEX
	) / (8760 * CT Capacity Factor)
	~	€/tCO2
	~		|

CT AF=
	1 / ((1-(1 + DISCOUNT RATE)^(-CT lifetime))/DISCOUNT RATE)
	~	
	~		|

CT Capacity Factor=
	0.9
	~	
	~	Own Assumption
	|

CT CAPEX=
	33*1000
	~	€/(tCO2/h)/km
	~	Technology Catalogue for Carbon Capture and Storage (ENS).
		Depends on pipeline location/size.
		
		Ranges from 13 - 18 - 33 - 53 - 130 €/(tCO2/h)/m
	|

industry CT revenue=
	fertilizer CT revenue+naphtha CT revenue+high temperature CT revenue+refinery CT revenue\
		+steel CT revenue
	~	M€
	~		|

CT lifetime=
	50
	~	years
	~		|

