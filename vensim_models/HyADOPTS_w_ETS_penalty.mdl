	/ NH3 LHV
	/ NH3 H2 usage * NH3 IS bid share
	~	t H2
	~		|

HD FCEV investment share=
	IF THEN ELSE(HD FCEV H2 subsidy>0.01, HD FCEV bid share, HD equalizer*HD FCEV level)
	~	percent
	~		|

naphtha equalizer=
	IF THEN ELSE( BioNaphtha H2 subsidy>0.01 , 
	   IF THEN ELSE( SynNaphtha H2 subsidy>0.01 , 
	                (1-SynNaphtha bid share-BioNaphtha bid share)/(Fossil naphtha level)\
		 ,
	                (1-BioNaphtha bid share)/(SynNaphtha level+Fossil naphtha level)) , 
	   IF THEN ELSE( SynNaphtha H2 subsidy>0.01 ,
	                (1-SynNaphtha bid share)/(BioNaphtha level+Fossil naphtha level) ,
	                 1/(BioNaphtha level+SynNaphtha level+Fossil naphtha level))
	)
	~	Dmnl
	~		|

refinery excess activity=
	MAX(refinery excess emissions / Grey H2 EF /10^6, 0) * Hard Regulation
	~	MT H2
	~		|

NH3 IS investment share=
	IF THEN ELSE(NH3 IS H2 subsidy>0.01, NH3 IS bid share, IS equalizer*NH3 IS level)
	~	Dmnl
	~		|

MeOH IS HBA volume=
	IS continuous investment * 3600
	/ MeOH LHV
	/ bioMeOH H2 usage * MeOH IS bid share
