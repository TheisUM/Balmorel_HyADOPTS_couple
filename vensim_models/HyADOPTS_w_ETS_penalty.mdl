	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2050
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2025
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 0.05
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.05
	~	Year [0,?]
	~	The time step for the simulation.
	|

