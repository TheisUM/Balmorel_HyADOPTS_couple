		) / 1000,
		0)
	~	M€
	~		|

fertilizer subsidy YTD= INTEG (
	IF THEN ELSE(
	  MODULO(Time, 1 ) >= TIME STEP ,
	  (Green H2 actual subsidy + fertilizer H2 actual subsidy) * fertilizer hydrogen demand\
		 / 1000 ,
	  -fertilizer subsidy YTD / TIME STEP ),
		0)
	~	M€
	~		|

