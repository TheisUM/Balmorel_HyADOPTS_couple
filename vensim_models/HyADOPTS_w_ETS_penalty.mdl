BioMeOH H2 WTP gap=Unsubsidized green H2 cost-bioMeOH H2 WTP
	~	€/kgH2
	~		|

fertilizer effective cost=(fertilizer average cost * NH3 LHV) / 1000
	* fertilizer current demand
	~	B€/Year
	~	€/GJ -> €/tNH3 = B€/MtNH3 * activity (MtNH3)
	|

refinery effective cost=refinery average cost * refinery current demand
	~	B€/Year
	~	kgH2 -> MtH2 conversion and € to B€ cancel out.
	|

MeOH effective cost=((MeOH average cost * MeOH LHV) / 1000)
	* MeOH current demand
	~	B€/Year
	~		|

LD effective cost=LD average cost * LD current demand / 1e+09
	~	B€/Year
	~		|

naphtha effective cost=((naphtha average cost*Naphtha LHV) / 1000)
	* naphtha current demand
	~	B€ / Year
	~	€/GJ -> €/ton -> B€/Mt * activity (Mt)
	|

IA effective cost=international aviation average cost * IA current demand / 1e+09
	~	B€/Year
	~		|

DS effective cost=domestic shipping average cost * DS current demand / 1e+09
	~	B€/Year
	~		|

DA effective cost=domestic aviation average cost * DA current demand / 1e+09
	~	B€/Year
	~		|

IS effective cost=international shipping average cost * IS current demand / 1e+09
	~	B€/Year
	~		|

HT effective cost=(high temperature average cost * 3600) / 1e+09
	* high temperature current demand
	~	B€/Year
	~	€/GJ to €/GWh to B€/GWh * activity (GWh)
	|

steel effective cost=(steel average cost / 1000)
	* steel current demand
	~	B€ / Year
	~	€/ton to €/Mt to B€/Mt * activity(Mt steel)
	|

HD effective cost=HD average cost * HD current demand / 1e+09
	~	B€/Year
	~		|

min alternative MeOH cost=convMeOH cost
	~	€/MJ
	~		|

LD H2 WTP=(LD ICE LCO - LD FC LCO without H2) / LD FC energy usage
	~	€/kg
	~		|

steel H2 marginal WTP=(BF BOF cost - (RENEWABLE ELECTRICITY PRICE) * (EL to Steel H2DRI\
		 /3.6))
	/ 1000 / H2 to steel
	~	€/kg
	~		|

HD H2 WTP=(HD ICE LCO - HD FC LCO without H2) / HD FC energy usage
	~	€/kg
	~		|

high temperature H2 WTP=Grey NG cost * 120 / 1000
	~	€/kg
	~		|

FC ship H2 WTP=(HFO ship cost - FC ship cost without H2) * H2 LHV / Yearly H2 Consumption\
		 / 1000 * 10^6
	~	€/kg
	~		|

Green H2 H2 WTP=Grey H2 cost
	~	€/kg
	~		|

steel H2 WTP=(BF BOF cost - H2DRI cost without H2) / 1000 / H2 to steel
	~	€/kgH2
	~		|

MeOH ship H2 WTP=((
	  (
	    HFO ship cost - MeOH ship cost without MeOH
	  )
	  / 3.6 / Yearly HFO Consumption * 10^6
	) - bioMeOH cost without H2) * bioMeOH H2 usage * MeOH LHV / 1000
	~	€/kg
	~		|

min alternative NH3 cost=Grey NH3 cost
	~	€/GJ
	~		|

H2FC DS H2 cost=MAX(0.1, IF THEN ELSE( H2FC DS H2 subsidy > 0, Derisked green H2 cost\
		, Green H2 cost) - H2FC DS H2 subsidy )
	+ (DS subsidy ban * 1000)
	~	€/kg
	~		|

DS subsidy ban=STEP(0, 2025)
	~	boolean
	~		|

Green H2 cost=MAX(
	Unsubsidized green H2 cost
	+ Green H2 tariff
	- Green H2 subsidy
	, 0.1)
	~	€/kgH2
	~	First CAPEX and OPEX is calculated as €/kWh input energy, then as €/kWh output \
		H2.
		Electricity costs are added on top, also as €/kWh output H2.
		Multiplied by LHV of H2 to change the value to €/kg
	|

Green H2 tariff=0
	~	€/kg
	~		|

HVO process cost wo H2=(
	  (
	    0*HVO Jet Electricity Usage * GRID ELECTRICITY PRICE +
	    0*HVO Jet Gas Usage * biogas cost * 3.6 +
	    HVO Jet Biomass usage * UCO PRICE * 3.6
	  )
	  +
	  (
	    (HVO Jet AF * HVO Jet CAPEX + HVO Jet OPEX) / HVO Jet operating hours +
	    HVO Jet variable)
	) / 3.6
	~	€/GJ output
	~		|

HT subsidy ban=STEP(0, 2025)
	~	boolean
	~		|

NM H2 cost=MAX(0.1, IF THEN ELSE( NM H2 subsidy > 0, Derisked green H2 cost, Green H2 cost\
		) - NM H2 subsidy )
	+ (HT subsidy ban * 1000)
	~	€/kgH2
	~		|

NM H2 GJ cost=NM H2 cost / 120 * 1000
	~	€/GJ
	~		|

HD FCEV H2 cost=MAX(0.1, IF THEN ELSE( HD FCEV H2 subsidy> 0, Derisked green H2 cost,\
		 Green H2 cost) - HD FCEV H2 subsidy )
	+ (HD subsidy ban * 1000)
	~	€/kg
	~		|

HD FCEV H2 subsidy limit=10^9
	~	M€
	~		|

HD subsidy ban=STEP(0, 2025)
	~	boolean
	~		|

UCO PRICE=BIOMASS PRICE
	~	€/GJ
	~	UCO: used cooking oil.
		Price is assumed to develop similarly to biomass.
		Source for historical cost: (around 900 $/t (25 $/GJ assuming LHV of 36 GJ/t) in \
		2024)
		https://www.spglobal.com/commodityinsights/en/market-insights/latest-news/a\
		griculture/100423-global-uco-supply-to-double-by-2030-as-us-eu-policies-dri\
		ve-asian-supply
	|

HD Fossil level=
	IF THEN ELSE(Hard Regulation<0.5,
	1 / ( 1 + EXP(SLOPE * (1 - HD Fossil competitiveness))) * MAX(0.1, HD Fossil sector share\
		), 
	MIN(1 / ( 1 + EXP(SLOPE * (1 - HD Fossil competitiveness))) * MAX(0.1, HD Fossil sector share\
		),
	HD Emissions cap lookup(Time)/(1-HD Emissions cap lookup(Time)) * HD Zero Emission level\
		)
	)
	~	Dmnl
	~	fossil_level / (fossil_level+zero_emissions_level) <= cap
		fossil_level <= cap * (fossil_level+zero_emissions_level)
		(1-cap) * fossil_level <= cap * zero_emissions_level
		fossil_level <= cap / (1-cap) * zero_emissions_level
		fossil_level = min(fossil_level, cap / (1-cap) * zero_emissions_level)
	|

HD Emissions cap lookup(
	[(0,0)-(10,10)],(2010,1),(2025,0.85),(2030,0.55),(2035,0.35),(2040,0.1),(2050,0.1))
	~	percent
	~	Maximum investment share of fossil trucks.
	|

HD Zero Emission level=
	HD BEV level + HD FCEV level
	~	
	~		|

biogas cost=(biogas AF * biogas CAPEX * 1000 + biogas OPEX * 2.28/3.42) * 1000 / biogas operating hours\
		 / 3.6 +
	biogas electricity usage * GRID ELECTRICITY PRICE / 3.6 +
	biogas heat usage * HEAT COST / 3.6 +
	biogas biomass usage * BIOMASS PRICE
	~	€/GJ
	~	Assumes 8500 full load hours - no mention of downtime in the tech. catalogue.
		OPEX multiplied by 2.28/3.42 to not double-count electricity and heat \
		costs.
	|

bioMeOH cost without H2=bioMeOH CAPEX * (bioMeOH AF + bioMeOH OPEX) / (bioMeOH operating hours\
		 * MeOH LHV) * 1000
	+
	(GRID ELECTRICITY PRICE * bioMeOH electricity usage - HEAT COST * bioMeOH excess heat\
		)
	/ MeOH LHV
	+
	bioMeOH biomass usage * BIOMASS PRICE
	~	€/GJ
	~	€/GJ MeOH
		
		[ [kgBM/kgMeOH] * [€/GJ] * [MJ/kgBM ] / [MJ/GJ]  + [€/kgH2]  / \
		[kgMeOH/kgH2] + [€/kWh * kWh/kgMeOH] ] / [MJ/kgMeOH]
	|

eMeOH cost without hydrogen=
	eMeOH CAPEX * (eMeOH AF + eMeOH OPEX) / (eMeOH operating hours * MeOH LHV) * 1000
	+
	(eMeOH CO2 usage * (PS CC cost/CC Capture Rate) + GRID ELECTRICITY PRICE * eMeOH electricity usage\
		 - HEAT COST * eMeOH excess heat
	) / MeOH LHV
	~	€/GJ
	~	€/GJ MeOH
		
		[ [kgBM/kgMeOH] * [€/GJ] * [MJ/kgBM ] / [MJ/GJ]  + [€/kgH2]  / \
		[kgMeOH/kgH2] + [€/kWh * kWh/kgMeOH] ] / [MJ/kgMeOH]
	|

Green NH3 cost without H2=
	NH3 CAPEX * (NH3 AF + NH3 OPEX) / (Green NH3 operating hours * NH3 LHV) * 1000 +
	NH3 el usage * GRID ELECTRICITY PRICE / NH3 LHV
	~	€/GJ
	~	€/GJ NH3
		
		[ [ [€/kgH2] / [kgNH3/kgH2] ] + [kWh/kgNH3 * €/kWh] ] / [MJ/kgNH3] + \
		[kWhe/kWhNH3 * €/kWhe] * [kWh/MJ]
	|

