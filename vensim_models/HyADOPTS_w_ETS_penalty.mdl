	DA continuous investment * HVO Kerosene H2 cost scaler * 3.6 * BioKero DA bid share
	~	t H2
	~		|

Derisked green H2 cost=
	MAX(Green H2 derisked CAPEX + Green H2 OPEX - Green H2 subsidy, 0.1)
	~	€/kgH2
	~		|

LD equalizer=
	IF THEN ELSE(LD FCEV H2 subsidy>0.01, (1-LD FCEV bid share)/(LD BEV level+LD Fossil level\
		) , 1/(LD Fossil level+LD FCEV level+LD BEV level))
	~	
	~		|

high temperature excess activity=
