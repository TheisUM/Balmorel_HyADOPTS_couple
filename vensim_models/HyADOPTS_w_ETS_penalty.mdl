	Unsubsidized green H2 cost-BioKero H2 WTP
	~	€/kgH2
	~		|

HBA=
	0
	~	boolean
	~	If 1, then sector subsidies are based on WTP gap, else on stated level.
	|

total H2DRI CAPEX subsidy= INTEG (
	H2DRI CAPEX subsidy * foundry lifetime * new H2DRI capacity,
		0)
	~	M€
	~		|

delay green h2 cost=
	DELAY FIXED(Green H2 cost, 10 , Green H2 cost )
	~	€/kg H2
	~		|

WAC green H2= INTEG (
	electrolyzer investments/electrolyser capacity * (Green H2 cost - WAC green H2) - support terminations\
		 / electrolyser capacity * (delay green h2 cost - WAC green H2),
		Green H2 cost * pilot plant capacity / electrolyser capacity)
	~	€/kgH2
	~		|

subsidized green H2 production=
	subsidized electrolysis capacity * electrolyser operating hours * AEC efficiency * 1000\
		 / 33.33
	~	t H2/Year
	~		|

yearly total subsidies limit=
	10000*100
	~	M€
	~		|

total subsidy cost= INTEG (
	subsidy payout,
		0)
	~	B€
	~		|

support terminations=
	DELAY FIXED(electrolyzer investments * pulse H2 subsidy, 10 , 0 )
	~	GW
	~		|

Green H2 subsidy=
	IF THEN ELSE(yearly total subsidies limit >= TOTAL SUBSIDIES YTD, Green H2 subsidy size\
		*pulse H2 subsidy, 0)
	~	€/kgH2
	~		|

subsidized electrolysis capacity= INTEG (
	electrolyzer investments * pulse H2 subsidy - support terminations,
		0)
	~	GW
	~		|

subsidy payout=
	subsidized green H2 production * Green H2 subsidy size / 10^6
	~	B€/Year
	~		|

H2 subsidy length=
	10
	~	years
	~		|

pulse H2 subsidy=
	PULSE( 2025 , H2 subsidy length)
	~	
	~		|

convMeOH emission factor=
	convMeOH gas usage * GAS EMISSION FACTOR
	~	tCO2/tMeOH
	~	Direct synthesis emissions + combustion emissions
	|

electrolyzer investments=
	MAX(0, missing production capacity)
	~	GW/yr
	~		|

AEC CAPEX=
	IF THEN ELSE(
	    electrolysis experience > 1,
	    One GW AEC CAPEX * (electrolysis experience) ^ ( LN(1-learning rate) / LN(2) ) ,
	    Initial GW AEC CAPEX - (Initial GW AEC CAPEX-One GW AEC CAPEX) * electrolysis experience
	)
	~	€/kWe
	~	If it is desired to use the Irena learning curve from Carmen's work:
		- Initial GW AEC CAPEX should be set to 650 €/kW.
		- One GW AEC CAPEX should be set to 600 €/kW.
		
		IF statement used to ensure reasonable costs at very low levels of \
		installed electrolysis.
	|

required electrolysis capacity=
	TOTAL GREEN HYDROGEN DEMAND * 33.33 / 1000 / AEC efficiency / electrolyser operating hours
	~	GW
	~		|

missing production capacity=
	required electrolysis capacity - electrolyser capacity
	~	GW
	~		|

total annual subsidies=
	Green H2 actual subsidy * (industry hydrogen demand + transportation hydrogen demand\
		) / 1000
	~	M€
	~		|

electrolyser capacity= INTEG (
	electrolyzer investments-electrolyzer decommissioning,
		pilot plant capacity)
	~	GW
	~	Hydrogen demand (tH2) * 1000 (kgH2/tH2) * 33.33 (kWhH2/kgH2) / efficiency \
		/ working hours (h) *10^-6 (GW/kW)= GW of electroliser capacity
	|

electrolysis experience= INTEG (
	electrolyzer investments,
		pilot plant capacity)
	~	GW
	~		|

FC EC induced learning curve=
	MIN(1, (electrolysis experience) ^ ( LN(1-learning rate/2) / LN(2) ))
	~	scalar
	~		|

