"hydrogen energy consumption dom. aviation"=
	"dom. aviation energy consumption"*"hydrogen penetration in dom. aviation"
	~	GWh
	~		|

"bio-kerosene energy consumption int. aviation"=
	"decarbonization curve int. aviation"*"int. aviation energy consumption"*1
	~	GWh
	~		|

"int. aviation energy consumption" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,486033),(2050,703496) ))
	~	GWh
	~		|

"decarbonization curve dom. aviation" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0),(2020,0),(2021,0.01),(2022,0.01),(2023,0.02),(2024,0.03),\
		(2025,0.04),(2026,0.05),(2027,0.07),(2028,0.09),(2029,0.12),(2030,0.16),(2031,0.2),\
		(2032,0.27),(2033,0.33),(2034,0.41),(2035,0.49),(2036,0.57),(2037,0.65),(2038,0.72)\
		,(2039,0.79),(2040,0.84),(2041,0.89),(2042,0.91),(2043,0.94),(2044,0.96),(2045,0.97\
		),(2046,0.98),(2047,0.99),(2048,0.99),(2049,0.996294),(2050,0.998147) ))
	~	
	~		|

"hydrogen penetration in dom. aviation" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0),(2020,0),(2021,0),(2022,0),(2023,0),(2024,0),(2025,0),(2026\
		,0),(2027,0),(2028,0),(2029,0),(2030
		,0),(2031,0),(2032,0.01),(2033,0.01),(2034,0.02),(2035,0.03),(2036,0.04),(2037,0.05\
		),(2038,0.07),(2039,0.09),(2040,0.12
		)
		,(2041,0.16),(2042,0.2),(2043,0.27),(2044,0.33),(2045,0.41),(2046,0.49),(2047,0.57)\
		,(2048,0.65),(2049,0.72),(2050,0.79
		) 
		))
	~	
	~		|

"decarbonization curve int. aviation" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0),(2020,0),(2021,0.01),(2022,0.01),(2023,0.02),(2024,0.03),\
		(2025,0.04),(2026,0.05),(2027,0.07),(2028,0.09),(2029,0.12),(2030,0.16),(2031,0.2),\
		(2032,0.27),(2033,0.33),(2034,0.41),(2035,0.49),(2036,0.57),(2037,0.65),(2038,0.72)\
		,(2039,0.79),(2040,0.84),(2041,0.89),(2042,0.91),(2043,0.94),(2044,0.96),(2045,0.97\
		),(2046,0.98),(2047,0.99),(2048,0.99),(2049,0.996294),(2050,0.998147) ))
	~	{%}
	~		|

"bio-kerosene energy consumption dom. aviation"=
	(("decarbonization curve dom. aviation"*"dom. aviation energy consumption")-"hydrogen energy consumption dom. aviation"\
		)*1
	~	
	~		|

"HYDROGEN F. AVIATON"=
	(("bio-kerosene energy consumption dom. aviation"+"bio-kerosene energy consumption int. aviation"\
		)*"bio kerosene - hydrogen rate"+("synthetic kerosene energy consumption dom. aviation"\
		+"synthetic kerosene energy consumption int. aviation")*"syn kerosene - hydrogen rate"\
		+"hydrogen energy consumption dom. aviation")*10^3/33.33
	~	t H2
	~	33.33 MWh/t = calorific power H2
	|

"dom. aviation energy consumption" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,75722),(2050,109601) ))
	~	GWh
	~		|

"synthetic kerosene energy consumption int. aviation"=
	"decarbonization curve int. aviation"*"int. aviation energy consumption"*0
	~	GWh
	~		|

"synthetic kerosene energy consumption dom. aviation"=
	(("dom. aviation energy consumption"*"decarbonization curve dom. aviation")-"hydrogen energy consumption dom. aviation"\
		)*0
	~	GWh
	~		|

"dom. navigation fossil energy consumption"=
	"dom. navigation fossil fuel demand"/ICE efficiency 0
	~	GWh
	~		|

"bio kerosene - hydrogen rate"=
	0.15
	~	MWh H2 / MWh kero
	~		|

"syn kerosene - hydrogen rate"=
	1.2
	~	MWh H2 / MWh kero
	~		|

biofuels share=
	IF THEN ELSE(rail electricity share<1, (0.1857*(Time-2019)+0.012)/100 , 0 )
	~	
	~		|

fossil energy consumption from rail=
	fossil energy demand/diesel locomotive efficiency
	~	GWh
	~		|

fossil energy demand=
	rail energy demand*(1-rail electricity share)*(1-biofuels share)
	~	
	~		|

rail electricity share = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0.7615),(2038,1),(2050,1) ))
	~	
	~		|

rail energy demand = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,47212),(2050,39177) ))
	~	GWh
	~		|

diesel locomotive efficiency=
	0.3
	~	
	~		|

AEC lifetime hours=
	70000
	~	h
	~	electrolyzer lifetime in hours
	|

electrolyser operating hours=
	4000
	~	h/Year
	~		|

"dom. navigation energy demand"=
	"dom. navigation energy consumption"*ICE efficiency 0
	~	GWh
	~		|

"dom. navigation energy consumption" = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,49177),(2050,97795) ))
	~	GWh
	~	Considering an annual growth rate of 2.64%
	|

BEV implementation curve = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0),(2020,0),(2021,0.01),(2022,0.01),(2023,0.02),(2024,0.03),\
		(2025,0.04),(2026,0.05),(2027,0.07),(2028,0.09),(2029,0.12),(2030,0.16),(2031,0.2),\
		(2032,0.27),(2033,0.33),(2034,0.41),(2035,0.49),(2036,0.57),(2037,0.65),(2038,0.72)\
		,(2039,0.79),(2040,0.84),(2041,0.89),(2042,0.91),(2043,0.94),(2044,0.96),(2045,0.97\
		),(2046,0.98),(2047,0.99),(2048,0.99),(2049,0.996294),(2050,0.998147) ))
	~	
	~		|

ICE efficiency 0=
	0.45
	~	
	~	Considering the same efficiency for all the fossil fuel engines
	|

"dom. navigation fossil fuel demand"=
	"dom. navigation energy demand"*(1-BEV implementation curve)
	~	GWh
	~		|

secondary sector growth = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,0.4),(2050,0.5) ))
	~	
	~	At the same time, the
		share of secondary steel production is expected to increase to 50%, as less scrap \
		will
		be exported out of Europe to now serve decarbonisation of steel production in the
		European market\!year\!share of steel production
	|

H2 to steel=
	0.0563
	~	tH2/tsteel
	~		|

steel projected demand=
	Steel Production Forecast*(1-secondary sector growth)
	~	MT steel
	~		|

secondary sector=
	Steel Production Forecast*secondary sector growth
	~	MT steel
	~		|

Steel Production Forecast = WITH LOOKUP (
	Time,
		([(0,0)-(10,10)],(2019,170),(2040,193),(2050,193) ))
	~	MT steel
	~	The change in European steel production is taken
		from Material Economics’ modelling based on EUROFER, which yields a  0.6% yearly
		increase in the steel stock/capacity up to the 2040s, when it stabilises at 193 \
		million
		tonnes per year, up from 170 million tonnes per year today.\!year\!Mt steel
	|

