	IF THEN ELSE(NM H2 subsidy>0.01, H2 NM bid share, NM equalizer*H2 NM level)
	~	percent
	~		|

H2FC DS HBA volume=
	DS continuous investment * ICE efficiency / FC efficiency * 3600 / H2 LHV * H2FC DS bid share
	~	t H2
	~		|

IS equalizer=
	IF THEN ELSE( MeOH IS H2 subsidy>0.01 , 
	   IF THEN ELSE( NH3 IS H2 subsidy>0.01 , 
	                (1-NH3 IS bid share-MeOH IS bid share)/(HFO IS level) ,
	                (1-MeOH IS bid share)/(NH3 IS level+HFO IS level)) , 
	   IF THEN ELSE( NH3 IS H2 subsidy>0.01 ,
	                (1-NH3 IS bid share)/(MeOH IS level+HFO IS level) ,
	                 1/(MeOH IS level+NH3 IS level+HFO IS level))
	)
	~	Dmnl
	~		|

H2DRI EAF HBA volume=
