	~	t H2
	~		|

BioKero IA HBA volume=
	IA continuous investment * HVO Kerosene H2 cost scaler * 3.6 * BioKero IA bid share
	~	t H2
	~		|

DA equalizer=
	IF THEN ELSE( BioKero H2 subsidy>0.01 , 
	   IF THEN ELSE( SynKero H2 subsidy>0.01 , 
	                (1-SynKero DA bid share-BioKero DA bid share)/(Jetfuel DA level) ,
	                (1-BioKero DA bid share)/(SynKero DA level+Jetfuel DA level)) , 
	   IF THEN ELSE( SynKero H2 subsidy>0.01 ,
	                (1-SynKero DA bid share)/(BioKero DA level+Jetfuel DA level) ,
	                 1/(BioKero DA level+SynKero DA level+Jetfuel DA level))
	)
	~	Dmnl
	~		|

SynKero IA investment share=
	IF THEN ELSE(SynKero H2 subsidy>0.01, SynKero IA bid share , IA equalizer*SynKero IA level\
		)
	~	Dmnl
	~		|

BioKero IA investment share=
	IF THEN ELSE(BioKero H2 subsidy>0.01, BioKero IA bid share, IA equalizer*BioKero IA level\
		)
	~	Dmnl
	~		|

BioKero DA investment share=
	IF THEN ELSE(BioKero H2 subsidy>0.01, BioKero DA bid share , DA equalizer*BioKero DA level\
		)
	~	Dmnl
	~		|

MeOH DS investment share=
	IF THEN ELSE(MeOH DS H2 subsidy>0.01, MeOH DS bid share , DS equalizer*MeOH DS level\
		 )
	~	Dmnl
	~		|

MeOH DS HBA volume=
	DS continuous investment * 3600
	/ MeOH LHV
	/ bioMeOH H2 usage * MeOH DS bid share
	~	t H2
	~		|

Green H2 derisked CAPEX=
	AEC CAPEX * 1 / ((1-(1 + INTEREST RATE)^(-AEC lifetime))/INTEREST RATE) / electrolyser operating hours\
		 / AEC efficiency * H2 LHV
	~	€/kW
	~		|

HD equalizer=
	IF THEN ELSE(HD FCEV H2 subsidy>0.01, (1-HD FCEV bid share)/(HD BEV level+HD Fossil level\
		), 1/(HD Fossil level+HD FCEV level+HD BEV level))
	~	
	~		|

