	~	t H2
	~		|

NH3 equalizer=
	IF THEN ELSE(fertilizer H2 subsidy>0.01, 
	(1-Green NH3 bid share)/(Blue NH3 level+Grey NH3 level) , 
	1/(Grey NH3 level+Green NH3 level+Blue NH3 level))
	~	Dmnl
	~		|

NM equalizer=
	IF THEN ELSE(NM H2 subsidy>0.01, 
	(1 - H2 NM bid share)/(Grey NG NM level + Blue NG NM level + Biogas NM level),
	1/(Grey NG NM level+H2 NM level+Blue NG NM level + Biogas NM level))
	~	
	~		|

Refinery equalizer=
	IF THEN ELSE(refinery H2 subsidy>0.01, 
	(1-Green Refinery bid share)/(Grey refinery level+Blue refinery level),
	1/(Grey refinery level+Green refinery level+Blue refinery level))
	~	
	~		|

Green NH3 investment share=
	IF THEN ELSE(fertilizer H2 subsidy>0.01, Green NH3 bid share , NH3 equalizer*Green NH3 level\
		)
	~	percent
	~		|

H2FC DS investment share=
	IF THEN ELSE(H2FC DS H2 subsidy>0.01, H2FC DS bid share, DS equalizer*H2FC DS level \
		)
	~	percent
	~		|

SynKero DA HBA volume=
	DA continuous investment * HtJ Kerosene H2 cost scaler * 3.6 * SynKero DA bid share
	~	t H2
	~		|

MeOH IS investment share=
	IF THEN ELSE(MeOH IS H2 subsidy>0.01, MeOH IS bid share, IS equalizer*MeOH IS level)
	~	Dmnl
	~		|

LD FCEV HBA volume=
	LD continuous investment * LD ICE efficiency / LD FCEV efficiency * 1000 / H2 LHV * \
		LD FCEV bid share
	~	t H2
	~		|

steel equalizer=
	IF THEN ELSE(steel H2 subsidy>0.01, 
	(1-H2DRI EAF bid share)/(BF BOF level+BF BOF CCS level+NGDRI EAF level) , 
	1/(BF BOF level+H2DRI EAF level+BF BOF CCS level+NGDRI EAF level))
	~	
	~		|

DS equalizer=
	IF THEN ELSE( MeOH DS H2 subsidy>0.01 , 
	   IF THEN ELSE( H2FC DS H2 subsidy>0.01 , 
	                (1-H2FC DS bid share-MeOH DS bid share)/(HFO DS level+Electric DS level\
		) ,
	                (1-MeOH DS bid share)/(H2FC DS level+HFO DS level+Electric DS level)\
		) , 
	   IF THEN ELSE( H2FC DS H2 subsidy>0.01 ,
	                (1-H2FC DS bid share)/(MeOH DS level+HFO DS level+Electric DS level)\
		 ,
	                 1/(HFO DS level+MeOH DS level+Electric DS level+H2FC DS level))
	)
	~	Dmnl
	~		|

BioMeOH investment share=
	
	IF THEN ELSE(BioMeOH H2 subsidy>0.01, BioMeOH bid share , equalizer MeOH*BioMeOH level\
		 )
	~	Dmnl
	~		|

BioNaphtha investment share=
	IF THEN ELSE(BioNaphtha H2 subsidy>0.01, BioNaphtha bid share , BioNaphtha level * naphtha equalizer\
		 )
	~	Dmnl
	~		|

BioNaphtha HBA volume=
	naphtha continuous investment * BioNaphtha H2 Usage / 33.33 * 10^6 * BioNaphtha bid share
	~	t H2
	~		|

SynKero DA investment share=
	IF THEN ELSE(SynKero H2 subsidy>0.01, SynKero DA bid share , DA equalizer*SynKero DA level\
		)
	~	Dmnl
	~		|

Tehnology Construction Time=
	1
	~	
	~		|

Sum of sector levels=
	Alternative levels + Technology level
	~	
	~		|

Technology cost=
	1
	~	
	~		|

relative ETS allowance cap=
	EMISSIONS CAP LOOKUP(Time)
	~	
	~		|

Technology Early Decommissioning=
	IF THEN ELSE(Technology Competitiveness < 0.5, Technology Stock * 0.1 , 0 )
	~	
	~		|

ETS allowance debt= INTEG (
	TOTAL EMISSIONS - ETS allowances,
		0)
	~	tCO2
	~		|

ETS allowances=
	initial emissions * relative ETS allowance cap
	~	tCO2
	~		|

ETS Clearing=
	0
	~	€/tCO2
	~		|

ETS debt CO2 WTP=
	CARBON TAX + 100
	~	€/tCO2
	~		|

initial emissions= INITIAL(
	TOTAL EMISSIONS)
	~	tCO2
	~		|

Alternative costs=
	1
	~	
	~		|

Alternative levels=
	0
	~	
	~		|

Technology Competitiveness=
	Alternative costs / Technology cost
	~	
	~	MIN( Blue H2 cost / refinery H2 cost , Grey H2 cost / refinery H2 cost )
	|

Technology Construction= INTEG (
	Technology Innovators+Technology Investment-Technology Commissioning,
		0)
	~	MT H2
	~		|

Technology level=
	1 / ( 1 + EXP(10 * (1 - Technology Competitiveness) ) ) * MAX(0.1, Technology sector share\
		)
	 + Technology Competitiveness * 0.001
	~	
	~		|

Technology Decommissioning=
	Technology Stock/Technology Lifetime
	~	MT H2/Year
	~		|

fertilizer excess activity=
	MAX(fertilizer excess emissions / Grey NH3 EF /10^6, 0) * MIN(Hard Regulation+ETS, 1\
		)
	~	MT NH3
	~		|

Technology Innovators=
	Sector Investment Pipeline * Technology innovator share * 0.05
	~	MT H2/Year
	~		|

Technology Investment=
	Sector Investment Pipeline * Technology investment share * 0.95
	~	MT H2/Year
	~		|

Technology investment share=
	Technology level / Sum of sector levels
	~	
	~		|

Technology sector share=
	1
	~	
	~		|

Technology Lifetime=
	1
	~	
	~		|

Sector Investment Pipeline=
	1
	~	
	~		|

Technology Commissioning=
	Technology Construction/Tehnology Construction Time
	~	MT H2/Year
	~		|

Technology Stock= INTEG (
	Technology Commissioning-Technology Decommissioning-Technology Early Decommissioning\
		,
		0)
	~	MT H2
	~		|

Technology innovator share=
	IF THEN ELSE(Technology Competitiveness > 0.5, 1, 0)
	~	
	~		|

CARBON TAX=
	IF THEN ELSE(ETS, SMOOTH(ETS Clearing, 3*TIME STEP) , CARBON TAX LOOKUP(Time) * CARBON TAX SENSITIVITY\
		)
	~	€/tCO2
	~	€/tCO2\!Time
	|

SynKero DA Commissioning subsidy level=
	DELAY FIXED(SynKero H2 subsidy + Green H2 subsidy, DA fuel switch time , 0 )
	~	€/kgH2
	~		|

SynKero DA extra investment=
	(SynSAF DA missing share + SAF DA missing share) * sum DA activity - BioKero DA extra investment
	~	GWh
	~		|

LD FCEV Commissioning subsidy level=
	DELAY FIXED(LD FCEV H2 subsidy + Green H2 subsidy, car procurement time, 0 )
	~	€/kgH2
	~		|

bid increase=
	1
	~	
	~		|

NH3 IS Commissioning subsidy level=
	DELAY FIXED(NH3 IS H2 subsidy + Green H2 subsidy, containership construction time , \
		0 )
	~	€/kgH2
	~		|

IA continuous investment=
	MAX((IA forecast demand +
	sum IA decommissioning +
	IA backlog / IA fuel switch time / 3 -
	sum IA activity -
	sum aviation extra investment) * (1 - innovators), 0)
	~	GWh/Year
	~		|

MeOH IS Commissioning subsidy level=
	DELAY FIXED(MeOH IS H2 subsidy + Green H2 subsidy, containership construction time, \
		0 )
	~	€/kgH2
	~		|

naphtha continuous investment=
	MAX((naphtha forecast demand +
	sum naphtha decommissioning + 
	naphtha backlog / feedstock switch time / 3 -
	sum naphtha activity) * (1 - innovators), 0)
	~	MT steel
	~		|

BioKero IA Commissioning subsidy level=
	DELAY FIXED(BioKero H2 subsidy + Green H2 subsidy, IA fuel switch time , 0 )
	~	€/kgH2
	~		|

aviation excess activity=
	sum IA activity * Jetfuel excess share
	~	GWh
	~		|

refinery continuous investment=
	MAX((refinery forecast demand +
	sum refinery decommissioning +
	refinery backlog / refinery construction time / 3 -
	sum refinery activity) * (1 - innovators), 0)
	~	MT H2
	~		|

BioKero IA extra investment=
	ZIDZ(BioKero IA level , BioKero IA level+SynKero IA level ) * SAF missing share * sum IA activity
	~	GWh
	~	The extra investment into SAF, which does not have to be synthetic fuels, \
		is divided between synth and bio SAF according to their usual investment \
		levels.
	|

DA continuous investment=
	MAX((DA forecast demand +
	sum DA decommissioning +
	DA backlog / DA fuel switch time / 3-
	sum DA activity -
	sum DA extra investment) * (1 - innovators), 0)
	~	GWh
	~		|

hba payout=
	BioKero DA subsidy cost+BioKero IA subsidy cost+BioMeOH subsidy cost+BioNaphtha subsidy cost\
		+eMeOH subsidy cost+Green NH3 subsidy cost+Green Refinery subsidy cost+H2DRI EAF subsidy cost\
		+H2FC DS subsidy cost+HD FCEV subsidy cost+LD FCEV subsidy cost+MeOH DS subsidy cost\
		+MeOH IS subsidy cost+NH3 IS subsidy cost+H2 NM subsidy cost+SynKero DA subsidy cost\
		+SynKero IA subsidy cost+SynNaphtha subsidy cost
	~	B€/Year
	~		|

DA excess activity=
	sum DA activity * Jetfuel DA excess share
	~	GWh
	~		|

eMeOH Commissioning subsidy level=
	DELAY FIXED(eMeOH H2 subsidy + Green H2 subsidy, MeOH construction time , 0 )
	~	€/kgH2
	~		|

HD continuous investment=
	MAX((HD forecast demand +
	sum HD decommissioning +
	HD backlog / truck procurement time / 3 -
	sum HD activity) * (1 - innovators), 0)
	~	GWh
	~		|

BioMeOH Commissioning subsidy level=
	DELAY FIXED(BioMeOH H2 subsidy + Green H2 subsidy, MeOH construction time , 0 )
	~	€/kgH2
	~		|

total hba cost= INTEG (
	hba payout,
		0)
	~	B€
	~		|

MeOH DS Commissioning subsidy level=
