ANNUAL CARBON TAX REVENUE=
	(CUMULATED CARBON TAX REVENUE - DELAY1(CUMULATED CARBON TAX REVENUE, 1 )) / 1000
	~	B€/Year
	~		|

light duty annual CT revenue=
	CARBON TAX * light duty emissions * 10^(-9)
	~	B€/Year
	~		|

LD lifetime=
	7
	~	years
	~	Financial investment horizon.
	|

LD AF=
	1 / ((1-(1 + DISCOUNT RATE)^(- LD lifetime ))/DISCOUNT RATE)
	~	percent
	~		|

LD scrappage value=
	0.25
	~	percent
	~	https://doi.org/10.1016/j.apenergy.2021.118079
	|

HD FC CAPEX=
	(HD FC powertrain CAPEX +HD FC storage CAPEX + HD rest of vehicle CAPEX) * (HD AF * \
		(1-HD scrappage value) + Vehicle insurance) / HD annual km
	~	€/km
	~		|

LD FC CAPEX=
	(LD FC engine CAPEX +LD FC storage CAPEX + LD rest of vehicle CAPEX) 
	 * (LD AF * (1-LD scrappage value) + Vehicle insurance) / LD annual km
	~	€/km
	~		|

HD scrappage value=
	0.18
	~	percent
	~	https://doi.org/10.1016/j.apenergy.2021.118079
	|

LD BE CAPEX=
	(LD BE engine CAPEX + LD BE storage CAPEX + LD rest of vehicle CAPEX)
	* (LD AF * (1-LD scrappage value) + Vehicle insurance) / LD annual km
	~	€/km
	~		|

HD BE CAPEX=
